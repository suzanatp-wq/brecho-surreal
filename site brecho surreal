<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Brechó Surreal — Achados Incríveis</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #f9f5ee;
  --green: #2d6a4f;
  --green-dark: #1b4332;
  --green-light: #d8f3dc;
  --orange: #f4a261;
  --orange-dark: #e07a3a;
  --white: #ffffff;
  --card-shadow: 0 2px 12px rgba(0,0,0,0.08);
  --text: #2c2c2c;
  --text-muted: #6b7280;
  --border: #e5e0d5;
  --font-size: 16px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{font-size:var(--font-size);}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;line-height:1.6;}

/* ── TOPBAR ── */
.topbar{background:var(--green);color:#fff;text-align:center;padding:7px 16px;font-size:0.78rem;letter-spacing:0.5px;}
.topbar span{margin:0 12px;}

/* ── HEADER ── */
header{background:var(--white);border-bottom:2px solid var(--border);padding:0 20px;position:sticky;top:0;z-index:200;box-shadow:0 2px 8px rgba(0,0,0,0.06);}
.header-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:16px;padding:12px 0;}
.logo{font-family:'Playfair Display',serif;font-size:1.7rem;color:var(--green);text-decoration:none;flex-shrink:0;}
.logo span{color:var(--orange);}
.header-actions{margin-left:auto;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.font-controls{display:flex;align-items:center;gap:4px;background:var(--bg);border-radius:8px;padding:4px 8px;}
.font-btn{background:none;border:1px solid var(--border);width:28px;height:28px;border-radius:6px;cursor:pointer;font-weight:600;color:var(--green);font-size:0.85rem;display:flex;align-items:center;justify-content:center;transition:all 0.15s;}
.font-btn:hover{background:var(--green);color:#fff;}
.font-label{font-size:0.72rem;color:var(--text-muted);letter-spacing:0.5px;}
.btn-admin-login{background:transparent;border:1.5px solid var(--green);color:var(--green);padding:6px 14px;border-radius:8px;font-size:0.8rem;font-weight:600;cursor:pointer;transition:all 0.15s;}
.btn-admin-login:hover{background:var(--green);color:#fff;}

/* ── NAV ── */
nav{background:var(--green);overflow-x:auto;}
.nav-inner{max-width:1100px;margin:0 auto;display:flex;gap:0;}
.nav-link{color:rgba(255,255,255,0.85);text-decoration:none;padding:12px 18px;font-size:0.85rem;font-weight:500;white-space:nowrap;transition:all 0.15s;border-bottom:3px solid transparent;}
.nav-link:hover,.nav-link.active{color:#fff;background:rgba(255,255,255,0.1);border-bottom-color:var(--orange);}

/* ── HERO ── */
.hero{background:linear-gradient(135deg,var(--green-dark) 0%,var(--green) 60%,#52b788 100%);color:#fff;padding:60px 20px;text-align:center;}
.hero h1{font-family:'Playfair Display',serif;font-size:2.6rem;margin-bottom:12px;line-height:1.2;}
.hero p{font-size:1.05rem;opacity:0.9;max-width:520px;margin:0 auto 24px;}
.hero-badges{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.hero-badge{background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.3);border-radius:20px;padding:6px 16px;font-size:0.82rem;}

/* ── INFO STRIP ── */
.info-strip{background:var(--orange);padding:10px 20px;}
.info-strip-inner{max-width:1100px;margin:0 auto;display:flex;gap:24px;justify-content:center;flex-wrap:wrap;align-items:center;}
.info-item{display:flex;align-items:center;gap:6px;color:#fff;font-size:0.83rem;font-weight:600;}

/* ── MAIN ── */
main{max-width:1100px;margin:0 auto;padding:32px 16px;}

/* ── SECTION ── */
.category-section{margin-bottom:48px;scroll-margin-top:80px;}
.section-header{display:flex;align-items:center;gap:12px;margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid var(--border);}
.section-icon{font-size:1.5rem;}
.section-title{font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--green);}
.section-count{background:var(--green-light);color:var(--green-dark);font-size:0.75rem;font-weight:600;padding:3px 10px;border-radius:12px;}

/* ── PRODUCT GRID ── */
.product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:18px;}
.product-card{background:var(--white);border-radius:14px;overflow:hidden;box-shadow:var(--card-shadow);border:1px solid var(--border);transition:transform 0.2s,box-shadow 0.2s;position:relative;}
.product-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,0.12);}
.product-img-wrap{width:100%;aspect-ratio:4/3;overflow:hidden;background:#f0ede6;position:relative;}
.product-img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.3s;}
.product-card:hover .product-img{transform:scale(1.04);}
.product-img-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color:#ccc;background:#f5f3ef;}
.card-body{padding:14px;}
.product-name{font-weight:600;font-size:0.95rem;color:var(--text);margin-bottom:4px;line-height:1.3;}
.product-desc{font-size:0.8rem;color:var(--text-muted);line-height:1.5;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.product-price{font-size:1.25rem;font-weight:700;color:var(--orange-dark);margin-bottom:10px;}
.product-price small{font-size:0.72rem;color:var(--text-muted);font-weight:400;display:block;margin-top:1px;}
.card-actions{display:flex;gap:6px;}
.btn-whatsapp{flex:1;background:var(--green);color:#fff;border:none;border-radius:8px;padding:8px 10px;font-size:0.78rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;transition:background 0.15s;text-decoration:none;}
.btn-whatsapp:hover{background:var(--green-dark);}
.btn-pix{background:var(--green-light);color:var(--green-dark);border:none;border-radius:8px;padding:8px 10px;font-size:0.78rem;font-weight:600;cursor:pointer;transition:background 0.15s;white-space:nowrap;}
.btn-pix:hover{background:#b7e4c7;}
.btn-edit-card{position:absolute;top:8px;right:8px;background:rgba(255,255,255,0.95);border:1px solid var(--border);border-radius:6px;padding:4px 8px;font-size:0.7rem;font-weight:600;color:var(--green);cursor:pointer;display:none;transition:all 0.15s;}
.btn-edit-card:hover{background:var(--green);color:#fff;}
.btn-del-card{position:absolute;top:8px;left:8px;background:rgba(255,255,255,0.95);border:1px solid #fca5a5;border-radius:6px;padding:4px 8px;font-size:0.7rem;font-weight:600;color:#dc2626;cursor:pointer;display:none;transition:all 0.15s;}
.btn-del-card:hover{background:#dc2626;color:#fff;}
body.admin-mode .btn-edit-card,body.admin-mode .btn-del-card{display:block;}

/* ── EMPTY STATE ── */
.empty-category{text-align:center;padding:40px 20px;color:var(--text-muted);background:var(--white);border-radius:14px;border:2px dashed var(--border);}
.empty-category p{margin-bottom:6px;font-size:0.9rem;}

/* ── ADMIN BAR ── */
.admin-bar{background:var(--green-dark);color:#fff;padding:10px 20px;display:none;align-items:center;gap:12px;flex-wrap:wrap;}
.admin-bar.visible{display:flex;}
.admin-bar span{font-size:0.85rem;font-weight:600;}
.btn-add-product{background:var(--orange);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-size:0.85rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;transition:background 0.15s;}
.btn-add-product:hover{background:var(--orange-dark);}
.btn-logout{background:transparent;border:1.5px solid rgba(255,255,255,0.4);color:#fff;padding:6px 12px;border-radius:8px;font-size:0.8rem;cursor:pointer;margin-left:auto;transition:all 0.15s;}
.btn-logout:hover{background:rgba(255,255,255,0.1);}
.btn-config{background:rgba(255,255,255,0.15);color:#fff;border:1.5px solid rgba(255,255,255,0.3);padding:6px 12px;border-radius:8px;font-size:0.8rem;cursor:pointer;transition:all 0.15s;}
.btn-config:hover{background:rgba(255,255,255,0.25);}

/* ── MODALS ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:1000;display:none;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--white);border-radius:18px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;padding:28px;}
.modal h2{font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--green);margin-bottom:20px;}
.form-group{margin-bottom:16px;}
.form-group label{display:block;font-size:0.82rem;font-weight:600;color:var(--text-muted);margin-bottom:5px;letter-spacing:0.3px;}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:0.9rem;font-family:'Inter',sans-serif;color:var(--text);background:var(--bg);transition:border-color 0.15s;outline:none;}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--green);}
.form-group textarea{resize:vertical;min-height:80px;}
.modal-actions{display:flex;gap:10px;margin-top:20px;}
.btn-save{flex:1;background:var(--green);color:#fff;border:none;border-radius:10px;padding:12px;font-size:0.95rem;font-weight:600;cursor:pointer;transition:background 0.15s;}
.btn-save:hover{background:var(--green-dark);}
.btn-cancel{background:transparent;border:1.5px solid var(--border);color:var(--text-muted);border-radius:10px;padding:12px 20px;font-size:0.95rem;cursor:pointer;transition:all 0.15s;}
.btn-cancel:hover{border-color:var(--text-muted);}
.btn-ai{width:100%;background:var(--green-light);color:var(--green-dark);border:1.5px solid var(--green);border-radius:8px;padding:10px;font-size:0.85rem;font-weight:600;cursor:pointer;margin-top:6px;transition:all 0.15s;display:flex;align-items:center;justify-content:center;gap:6px;}
.btn-ai:hover{background:var(--green);color:#fff;}
.btn-ai:disabled{opacity:0.55;cursor:not-allowed;}
.ai-status{font-size:0.8rem;color:var(--green);text-align:center;margin-top:6px;min-height:20px;}
.img-preview-wrap{margin-top:8px;border-radius:10px;overflow:hidden;border:1.5px dashed var(--border);display:none;}
.img-preview-wrap img{width:100%;max-height:200px;object-fit:cover;display:block;}
.img-preview-wrap.show{display:block;}

/* ── PIX MODAL ── */
.pix-info{background:var(--green-light);border-radius:12px;padding:20px;text-align:center;margin:16px 0;}
.pix-key{font-size:1.2rem;font-weight:700;color:var(--green-dark);letter-spacing:1px;margin-bottom:8px;}
.pix-copy-btn{background:var(--green);color:#fff;border:none;border-radius:8px;padding:8px 20px;font-size:0.85rem;font-weight:600;cursor:pointer;transition:background 0.15s;}
.pix-copy-btn:hover{background:var(--green-dark);}
.pix-product-name{font-weight:600;font-size:1rem;margin-bottom:4px;}
.pix-product-price{font-size:1.5rem;font-weight:700;color:var(--orange-dark);margin-bottom:12px;}

/* ── LOGIN MODAL ── */
.login-error{background:#fee2e2;color:#dc2626;border-radius:8px;padding:10px;font-size:0.85rem;text-align:center;margin-top:8px;display:none;}
.login-error.show{display:block;}

/* ── CONFIG MODAL ── */
.config-section{margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border);}
.config-section:last-child{border-bottom:none;margin-bottom:0;}
.config-section h3{font-size:0.9rem;font-weight:600;color:var(--green);margin-bottom:12px;}

/* ── FOOTER ── */
footer{background:var(--green-dark);color:rgba(255,255,255,0.75);text-align:center;padding:32px 20px;margin-top:40px;}
footer .footer-logo{font-family:'Playfair Display',serif;font-size:1.4rem;color:#fff;margin-bottom:8px;}
footer p{font-size:0.82rem;margin-bottom:6px;}
footer .pix-footer{background:rgba(255,255,255,0.1);border-radius:8px;padding:10px 20px;display:inline-block;margin:10px 0;font-size:0.85rem;color:#fff;}

/* ── WHATSAPP FLOAT ── */
.wa-float{position:fixed;bottom:24px;right:24px;z-index:500;width:58px;height:58px;background:#25d366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(37,211,102,0.5);cursor:pointer;transition:transform 0.2s;text-decoration:none;}
.wa-float:hover{transform:scale(1.1);}
.wa-float svg{width:30px;height:30px;fill:#fff;}

/* ── TOAST ── */
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:#1b4332;color:#fff;padding:10px 24px;border-radius:24px;font-size:0.88rem;font-weight:600;z-index:9999;opacity:0;transition:opacity 0.3s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;}

/* ── UPLOAD AREA ── */
.upload-area{border:2px dashed var(--border);border-radius:10px;padding:20px;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--bg);}
.upload-area:hover,.upload-area.dragover{border-color:var(--green);background:var(--green-light);}
.upload-area p{font-size:0.85rem;color:var(--text-muted);margin-top:6px;}

/* ── API KEY SETUP ── */
.api-setup{background:#fffbeb;border:1.5px solid #fcd34d;border-radius:10px;padding:14px 16px;margin-bottom:16px;}
.api-setup p{font-size:0.82rem;color:#92400e;margin-bottom:6px;}
.api-setup a{color:#d97706;font-weight:600;}

/* ── RESPONSIVE ── */
@media(max-width:700px){
  .hero h1{font-size:1.8rem;}
  .product-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;}
  .nav-link{padding:10px 12px;font-size:0.78rem;}
  .header-inner{flex-wrap:wrap;gap:8px;}
  .font-controls{order:3;}
  .modal{padding:20px;}
}
@media(max-width:400px){
  .product-grid{grid-template-columns:1fr 1fr;}
  .card-actions{flex-direction:column;}
}
</style>
</head>
<body>

<!-- TOP INFO -->
<div class="topbar">
  <span>🚚 Frete por conta do comprador</span>
  <span>💵 Pagamento: Dinheiro ou PIX</span>
  <span>✅ Itens verificados pelo vendedor</span>
</div>

<!-- ADMIN BAR -->
<div class="admin-bar" id="adminBar">
  <span>⚙️ Modo Administrador</span>
  <button class="btn-add-product" onclick="openAddProduct()">➕ Adicionar Produto</button>
  <button class="btn-config" onclick="openConfig()">⚙️ Configurações</button>
  <button class="btn-logout" onclick="doLogout()">Sair</button>
</div>

<!-- HEADER -->
<header>
  <div class="header-inner">
