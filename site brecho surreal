<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- ═══ MODAIS ═══ -->

<!-- LOGIN -->
<div class="modal-overlay" id="loginModal">
  <div class="modal" style="max-width:380px;">
    <h2>🔐 Área do Administrador</h2>
    <div class="form-group">
      <label>Usuário</label>
      <input type="text" id="loginUser" placeholder="admin" autocomplete="username"/>
    </div>
    <div class="form-group">
      <label>Senha</label>
      <input type="password" id="loginPass" placeholder="••••••" autocomplete="current-password" onkeydown="if(event.key==='Enter')doLogin()"/>
    </div>
    <div class="login-error" id="loginError">Usuário ou senha incorretos.</div>
    <div class="modal-actions">
      <button class="btn-save" onclick="doLogin()">Entrar</button>
      <button class="btn-cancel" onclick="closeModal('loginModal')">Cancelar</button>
    </div>
  </div>
</div>

<!-- ADD / EDIT PRODUCT -->
<div class="modal-overlay" id="productModal">
  <div class="modal">
    <h2 id="productModalTitle">➕ Adicionar Produto</h2>

    <div class="api-setup" id="apiSetupHint" style="display:none;">
      <p><strong>🤖 Para usar a IA:</strong> insira sua chave da Anthropic abaixo nas configurações. Crie grátis em <a href="https://console.anthropic.com/keys" target="_blank">console.anthropic.com</a></p>
    </div>

    <div class="form-group">
      <label>Foto do Produto</label>
      <div class="upload-area" id="uploadArea" onclick="document.getElementById('photoInput').click()">
        <div style="font-size:2rem;">📷</div>
        <p>Clique aqui para escolher uma foto<br>ou arraste a imagem</p>
      </div>
      <input type="file" id="photoInput" accept="image/*" style="display:none;" onchange="onPhotoSelected(this)"/>
      <div class="img-preview-wrap" id="imgPreviewWrap">
        <img id="imgPreview" src="" alt="preview"/>
      </div>
      <button class="btn-ai" id="btnAnalyzeAI" onclick="analyzeWithAI()" disabled>
        ✨ Analisar com IA e preencher automaticamente
      </button>
      <div class="ai-status" id="aiStatus"></div>
    </div>

    <div class="form-group">
      <label>Nome do Produto *</label>
      <input type="text" id="prodName" placeholder="Ex: Batedeira Arno 250W"/>
    </div>
    <div class="form-group">
      <label>Categoria *</label>
      <select id="prodCategory">
        <option value="">Selecione...</option>
        <option value="eletrodomesticos">Eletrodomésticos</option>
        <option value="roupas">Roupas</option>
        <option value="calcados">Calçados</option>
        <option value="ferramentas">Ferramentas</option>
        <option value="moveis">Móveis</option>
        <option value="eletronicos">Eletrônicos</option>
        <option value="outros">Outros</option>
      </select>
    </div>
    <div class="form-group">
      <label>Descrição</label>
      <textarea id="prodDesc" placeholder="Descreva o estado e características do produto..."></textarea>
    </div>
    <div class="form-group">
      <label>Preço (R$) *</label>
      <input type="number" id="prodPrice" placeholder="Ex: 45.00" step="0.01" min="0"/>
    </div>
    <div class="modal-actions">
      <button class="btn-save" onclick="saveProduct()">💾 Salvar Produto</button>
      <button class="btn-cancel" onclick="closeModal('productModal')">Cancelar</button>
    </div>
  </div>
</div>

<!-- PIX MODAL -->
<div class="modal-overlay" id="pixModal">
  <div class="modal" style="max-width:400px;text-align:center;">
    <h2>💳 Pagar com PIX</h2>
    <div class="pix-info">
      <div class="pix-product-name" id="pixProductName"></div>
      <div class="pix-product-price" id="pixProductPrice"></div>
      <div style="font-size:0.82rem;color:var(--green-dark);margin-bottom:8px;">Chave PIX:</div>
      <div class="pix-key" id="pixKeyDisplay"></div>
      <button class="pix-copy-btn" onclick="copyPix()">📋 Copiar chave PIX</button>
    </div>
    <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:16px;">Após o pagamento, envie o comprovante via WhatsApp para confirmar o pedido.</p>
    <button class="btn-whatsapp" style="width:100%;border-radius:10px;padding:12px;font-size:0.9rem;" id="pixWaBtn" onclick="closeModal('pixModal')">
      📲 Confirmar pedido no WhatsApp
    </button>
    <button class="btn-cancel" style="width:100%;margin-top:8px;border-radius:10px;padding:10px;" onclick="closeModal('pixModal')">Fechar</button>
  </div>
</div>

<!-- CONFIG MODAL -->
<div class="modal-overlay" id="configModal">
  <div class="modal">
    <h2>⚙️ Configurações do Site</h2>

    <div class="config-section">
      <h3>📲 WhatsApp</h3>
      <div class="form-group">
        <label>Número do WhatsApp (com DDD, sem espaços)</label>
        <input type="text" id="cfgWa" placeholder="5511999999999"/>
      </div>
    </div>

    <div class="config-section">
      <h3>💳 PIX</h3>
      <div class="form-group">
        <label>Chave PIX (celular, CPF, e-mail ou chave aleatória)</label>
        <input type="text" id="cfgPix" placeholder="Ex: 11999999999"/>
      </div>
    </div>

    <div class="config-section">
      <h3>🤖 IA (Anthropic)</h3>
      <div class="form-group">
        <label>Chave de API da Anthropic</label>
        <input type="password" id="cfgApiKey" placeholder="sk-ant-api03-..."/>
      </div>
      <p style="font-size:0.78rem;color:var(--text-muted);">Crie gratuitamente em <a href="https://console.anthropic.com/keys" target="_blank" style="color:var(--green);">console.anthropic.com/keys</a></p>
    </div>

    <div class="config-section">
      <h3>🔐 Acesso Admin</h3>
      <div class="form-group">
        <label>Usuário</label>
        <input type="text" id="cfgUser" placeholder="admin"/>
      </div>
      <div class="form-group">
        <label>Nova senha</label>
        <input type="password" id="cfgPass" placeholder="deixe em branco para não alterar"/>
      </div>
    </div>

    <div class="modal-actions">
      <button class="btn-save" onclick="saveConfig()">💾 Salvar Configurações</button>
      <button class="btn-cancel" onclick="closeModal('configModal')">Cancelar</button>
    </div>
  </div>
</div>

<!-- ═══ SCRIPT ═══ -->
<script>
// ─── CONFIG PADRÃO ───────────────────────────────────────────────
const DEFAULT_CONFIG = {
  waNumber: '5511999999999',
  pixKey: 'brecho.surreal@pix.com',
  adminUser: 'admin',
  adminPass: 'brecho2024',
  apiKey: ''
};

const CATEGORIES = [
  { id: 'eletrodomesticos', label: 'Eletrodomésticos', icon: '🏠' },
  { id: 'roupas',           label: 'Roupas',           icon: '👕' },
  { id: 'calcados',         label: 'Calçados',         icon: '👟' },
  { id: 'ferramentas',      label: 'Ferramentas',      icon: '🔧' },
  { id: 'moveis',           label: 'Móveis',           icon: '🪑' },
  { id: 'eletronicos',      label: 'Eletrônicos',      icon: '📱' },
  { id: 'outros',           label: 'Outros',           icon: '📦' },
];

// ─── STATE ───────────────────────────────────────────────────────
let config = loadConfig();
let products = loadProducts();
let isAdmin = false;
let editingProductId = null;
let currentPhotoBase64 = null;
let currentPhotoMime = null;
let currentPixProduct = null;
let fontSize = 16;

// ─── INIT ─────────────────────────────────────────────────────────
function init() {
  renderAll();
  updateWaFloat();
  updateFooterPix();
  // nav active on scroll
  window.addEventListener('scroll', updateNavActive);
  // drag & drop upload
  const ua = document.getElementById('uploadArea');
  ua.addEventListener('dragover', e => { e.preventDefault(); ua.classList.add('dragover'); });
  ua.addEventListener('dragleave', () => ua.classList.remove('dragover'));
  ua.addEventListener('drop', e => {
    e.preventDefault();
    ua.classList.remove('dragover');
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) handlePhotoFile(file);
  });
}

// ─── STORAGE ─────────────────────────────────────────────────────
function loadConfig() {
  try { return { ...DEFAULT_CONFIG, ...JSON.parse(localStorage.getItem('bs_config') || '{}') }; }
  catch(e) { return { ...DEFAULT_CONFIG }; }
}

function saveConfigToStorage() {
  localStorage.setItem('bs_config', JSON.stringify(config));
}

function loadProducts() {
  try { return JSON.parse(localStorage.getItem('bs_products') || '[]'); }
  catch(e) { return []; }
}

function saveProductsToStorage() {
  localStorage.setItem('bs_products', JSON.stringify(products));
}

// ─── RENDER ───────────────────────────────────────────────────────
function renderAll() {
  const container = document.getElementById('categorySections');
  container.innerHTML = '';
  CATEGORIES.forEach(cat => {
    const catProducts = products.filter(p => p.category === cat.id);
    const section = document.createElement('section');
    section.className = 'category-section';
    section.id = cat.id;
    section.innerHTML = `
      <div class="section-header">
        <span class="section-icon">${cat.icon}</span>
        <h2 class="section-title">${cat.label}</h2>
        <span class="section-count">${catProducts.length} ${catProducts.length === 1 ? 'item' : 'itens'}</span>
      </div>
      <div class="product-grid" id="grid-${cat.id}">
        ${catProducts.length === 0
          ? `<div class="empty-category" style="grid-column:1/-1;">
               <p>Nenhum produto nesta categoria ainda.</p>
               ${isAdmin ? '<p style="font-size:0.8rem;">Use o botão <strong>Adicionar Produto</strong> no topo para começar.</p>' : ''}
             </div>`
          : catProducts.map(p => productCardHTML(p)).join('')
        }
      </div>`;
    container.appendChild(section);
  });
}

function productCardHTML(p) {
  const price = parseFloat(p.price || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
  const imgContent = p.photo
    ? `<img class="product-img" src="${p.photo}" alt="${escHtml(p.name)}" loading="lazy"/>`
    : `<div class="product-img-placeholder">${CATEGORIES.find(c=>c.id===p.category)?.icon || '📦'}</div>`;
  const waUrl = `https://wa.me/${config.waNumber}?text=${encodeURIComponent(`Olá! Tenho interesse no produto: *${p.name}* por *${price}*. Ainda está disponível? 😊`)}`;
  return `
    <div class="product-card" id="pcard-${p.id}">
      <button class="btn-del-card" onclick="deleteProduct('${p.id}')">🗑</button>
      <button class="btn-edit-card" onclick="openEditProduct('${p.id}')">✏️ Editar</button>
      <div class="product-img-wrap">${imgContent}</div>
      <div class="card-body">
        <div class="product-name">${escHtml(p.name)}</div>
        <div class="product-desc">${escHtml(p.description || '')}</div>
        <div class="product-price">${price}<small>Frete por conta do comprador</small></div>
        <div class="card-actions">
          <a class="btn-whatsapp" href="${waUrl}" target="_blank">📲 WhatsApp</a>
          <button class="btn-pix" onclick="openPix('${p.id}')">💳 PIX</button>
        </div>
      </div>
    </div>`;
}

function escHtml(str) {
  return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ─── FONT SIZE ────────────────────────────────────────────────────
function adjustFont(delta) {
  fontSize = Math.min(22, Math.max(12, fontSize + delta));
  document.documentElement.style.setProperty('--font-size', fontSize + 'px');
}

// ─── NAV ──────────────────────────────────────────────────────────
function scrollTo(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function updateNavActive() {
  const sections = ['inicio', ...CATEGORIES.map(c => c.id)];
  let current = 'inicio';
  sections.forEach(id => {
    const el = document.getElementById(id);
    if (el && window.scrollY >= el.offsetTop - 100) current = id;
  });
  document.querySelectorAll('.nav-link').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
}

// ─── WHATSAPP & PIX ───────────────────────────────────────────────
function updateWaFloat() {
  const wa = document.getElementById('waFloat');
  wa.href = `https://wa.me/${config.waNumber}?text=${encodeURIComponent('Olá! Vim pelo site do Brechó Surreal e quero saber mais sobre os produtos.')}`;
}

function updateFooterPix() {
  document.getElementById('footerPix').textContent = '🔑 PIX: ' + config.pixKey;
}

function openPix(productId) {
  const p = products.find(x => x.id === productId);
  if (!p) return;
  const price = parseFloat(p.price || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
  document.getElementById('pixProductName').textContent = p.name;
  document.getElementById('pixProductPrice').textContent = price;
  document.getElementById('pixKeyDisplay').textContent = config.pixKey;
  const waUrl = `https://wa.me/${config.waNumber}?text=${encodeURIComponent(`Olá! Acabei de fazer o PIX para: *${p.name}* (${price}). Segue o comprovante! 🤝`)}`;
  document.getElementById('pixWaBtn').onclick = () => { window.open(waUrl, '_blank'); closeModal('pixModal'); };
  openModal('pixModal');
}

function copyPix() {
  navigator.clipboard.writeText(config.pixKey).then(() => showToast('Chave PIX copiada!'));
}

// ─── LOGIN / LOGOUT ───────────────────────────────────────────────
function openLogin() {
  if (isAdmin) { doLogout(); return; }
  openModal('loginModal');
  setTimeout(() => document.getElementById('loginUser').focus(), 100);
}

function doLogin() {
  const u = document.getElementById('loginUser').value.trim();
  const p = document.getElementById('loginPass').value;
  if (u === config.adminUser && p === config.adminPass) {
    isAdmin = true;
    document.body.classList.add('admin-mode');
    document.getElementById('adminBar').classList.add('visible');
    document.getElementById('btnAdminToggle').textContent = '🔓 Sair';
    document.getElementById('loginError').classList.remove('show');
    closeModal('loginModal');
    showToast('✅ Bem-vindo, administrador!');
  } else {
    document.getElementById('loginError').classList.add('show');
    document.getElementById('loginPass').value = '';
  }
}

function doLogout() {
  isAdmin = false;
  document.body.classList.remove('admin-mode');
  document.getElementById('adminBar').classList.remove('visible');
  document.getElementById('btnAdminToggle').textContent = 'Admin';
  showToast('Você saiu do modo administrador.');
}

// ─── ADD / EDIT PRODUCT ───────────────────────────────────────────
function openAddProduct() {
  editingProductId = null;
  currentPhotoBase64 = null;
  currentPhotoMime = null;
  document.getElementById('productModalTitle').textContent = '➕ Adicionar Produto';
  document.getElementById('prodName').value = '';
  document.getElementById('prodCategory').value = '';
  document.getElementById('prodDesc').value = '';
  document.getElementById('prodPrice').value = '';
  document.getElementById('imgPreviewWrap').classList.remove('show');
  document.getElementById('imgPreview').src = '';
  document.getElementById('aiStatus').textContent = '';
  document.getElementById('btnAnalyzeAI').disabled = true;
  document.getElementById('photoInput').value = '';
  document.getElementById('apiSetupHint').style.display = config.apiKey ? 'none' : 'block';
  openModal('productModal');
}

function openEditProduct(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  editingProductId = id;
  currentPhotoBase64 = null;
  currentPhotoMime = null;
  document.getElementById('productModalTitle').textContent = '✏️ Editar Produto';
  document.getElementById('prodName').value = p.name || '';
  document.getElementById('prodCategory').value = p.category || '';
  document.getElementById('prodDesc').value = p.description || '';
  document.getElementById('prodPrice').value = p.price || '';
  document.getElementById('aiStatus').textContent = '';
  document.getElementById('apiSetupHint').style.display = config.apiKey ? 'none' : 'block';
  if (p.photo) {
    document.getElementById('imgPreview').src = p.photo;
    document.getElementById('imgPreviewWrap').classList.add('show');
    document.getElementById('btnAnalyzeAI').disabled = !config.apiKey;
  } else {
    document.getElementById('imgPreviewWrap').classList.remove('show');
    document.getElementById('btnAnalyzeAI').disabled = true;
  }
  openModal('productModal');
}

function onPhotoSelected(input) {
  const file = input.files[0];
  if (file) handlePhotoFile(file);
}

function handlePhotoFile(file) {
  const reader = new FileReader();
  reader.onload = e => {
    const dataUrl = e.target.result;
    document.getElementById('imgPreview').src = dataUrl;
    document.getElementById('imgPreviewWrap').classList.add('show');
    currentPhotoBase64 = dataUrl.split(',')[1];
    currentPhotoMime = file.type;
    document.getElementById('btnAnalyzeAI').disabled = !config.apiKey;
    if (!config.apiKey) {
      document.getElementById('apiSetupHint').style.display = 'block';
      document.getElementById('aiStatus').textContent = '⚠️ Configure a chave de API para usar a IA.';
    } else {
      document.getElementById('aiStatus').textContent = '📷 Foto carregada! Clique em "Analisar com IA".';
    }
  };
  reader.readAsDataURL(file);
}

async function analyzeWithAI() {
  if (!currentPhotoBase64 && !editingProductId) return;
  const btn = document.getElementById('btnAnalyzeAI');
  const status = document.getElementById('aiStatus');
  btn.disabled = true;
  status.textContent = '🤖 Analisando com IA...';

  // if editing and no new photo, use existing
  let b64 = currentPhotoBase64;
  let mime = currentPhotoMime;
  if (!b64 && editingProductId) {
    const p = products.find(x => x.id === editingProductId);
    if (p && p.photo) {
      b64 = p.photo.split(',')[1];
      mime = p.photo.split(';')[0].replace('data:', '');
    }
  }

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': config.apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 800,
        messages: [{
          role: 'user',
          content: [
            { type: 'image', source: { type: 'base64', media_type: mime, data: b64 } },
            { type: 'text', text: `Analise esta foto de produto para um brechó brasileiro chamado "Brechó Surreal". Retorne APENAS JSON válido sem markdown:\n{"nome":"nome atraente do produto (máx 40 chars)","categoria":"uma de: eletrodomesticos | roupas | calcados | ferramentas | moveis | eletronicos | outros","descricao":"descrição de venda de 1-2 frases, destaque estado e pontos positivos","preco":número em reais apenas para brechó usado no Brasil}` }
          ]
        }]
      })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error?.message || 'Erro na API');
    const text = data.content.map(b => b.text || '').join('');
    const clean = text.replace(/```json|```/g,'').trim();
    const info = JSON.parse(clean);
    document.getElementById('prodName').value = info.nome || '';
    document.getElementById('prodCategory').value = info.categoria || '';
    document.getElementById('prodDesc').value = info.descricao || '';
    document.getElementById('prodPrice').value = info.preco || '';
    status.textContent = '✅ Preenchido pela IA! Confira e ajuste se quiser.';
  } catch(e) {
    status.textContent = '❌ Erro: ' + (e.message || 'Tente novamente.');
  } finally {
    btn.disabled = false;
  }
}

function saveProduct() {
  const name = document.getElementById('prodName').value.trim();
  const category = document.getElementById('prodCategory').value;
  const desc = document.getElementById('prodDesc').value.trim();
  const price = parseFloat(document.getElementById('prodPrice').value);

  if (!name) { showToast('⚠️ Preencha o nome do produto.'); return; }
  if (!category) { showToast('⚠️ Selecione uma categoria.'); return; }
  if (isNaN(price) || price < 0) { showToast('⚠️ Informe um preço válido.'); return; }

  if (editingProductId) {
    const idx = products.findIndex(p => p.id === editingProductId);
    if (idx !== -1) {
      products[idx] = {
        ...products[idx],
        name, category, description: desc, price,
        photo: currentPhotoBase64
          ? 'data:' + currentPhotoMime + ';base64,' + currentPhotoBase64
          : products[idx].photo
      };
      showToast('✅ Produto atualizado!');
    }
  } else {
    const newP = {
      id: Date.now().toString(),
      name, category, description: desc, price,
      photo: currentPhotoBase64 ? 'data:' + currentPhotoMime + ';base64,' + currentPhotoBase64 : null,
      createdAt: new Date().toISOString()
    };
    products.unshift(newP);
    showToast('✅ Produto adicionado!');
  }
  saveProductsToStorage();
  renderAll();
  closeModal('productModal');
}

function deleteProduct(id) {
  if (!confirm('Deseja realmente remover este produto?')) return;
  products = products.filter(p => p.id !== id);
  saveProductsToStorage();
  renderAll();
  showToast('🗑 Produto removido.');
}

// ─── CONFIG ───────────────────────────────────────────────────────
function openConfig() {
  document.getElementById('cfgWa').value = config.waNumber || '';
  document.getElementById('cfgPix').value = config.pixKey || '';
  document.getElementById('cfgApiKey').value = config.apiKey || '';
  document.getElementById('cfgUser').value = config.adminUser || '';
  document.getElementById('cfgPass').value = '';
  openModal('configModal');
}

function saveConfig() {
  const newPass = document.getElementById('cfgPass').value;
  config.waNumber = document.getElementById('cfgWa').value.trim() || config.waNumber;
  config.pixKey = document.getElementById('cfgPix').value.trim() || config.pixKey;
  config.apiKey = document.getElementById('cfgApiKey').value.trim();
  config.adminUser = document.getElementById('cfgUser').value.trim() || config.adminUser;
  if (newPass) config.adminPass = newPass;
  saveConfigToStorage();
  updateWaFloat();
  updateFooterPix();
  closeModal('configModal');
  showToast('✅ Configurações salvas!');
}

// ─── MODAL HELPERS ────────────────────────────────────────────────
function openModal(id) {
  document.getElementById(id).classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow = '';
}
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
});

// ─── TOAST ────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2800);
}

// ─── START ────────────────────────────────────────────────────────
init();
</script>
</body>
</html>
