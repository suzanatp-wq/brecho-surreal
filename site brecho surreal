      <div class="font-controls">
        <span class="font-label">A</span>
        <button class="font-btn" onclick="adjustFont(-1)" title="Diminuir fonte">A−</button>
        <button class="font-btn" onclick="adjustFont(1)" title="Aumentar fonte">A+</button>
      </div>
      <button class="btn-admin-login" id="btnAdminToggle" onclick="openLogin()">Admin</button>
    </div>
  </div>
</header>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a class="nav-link" href="#inicio" onclick="scrollTo('inicio')">Início</a>
    <a class="nav-link" href="#eletrodomesticos" onclick="scrollTo('eletrodomesticos')">Eletrodomésticos</a>
    <a class="nav-link" href="#roupas" onclick="scrollTo('roupas')">Roupas</a>
    <a class="nav-link" href="#calcados" onclick="scrollTo('calcados')">Calçados</a>
    <a class="nav-link" href="#ferramentas" onclick="scrollTo('ferramentas')">Ferramentas</a>
    <a class="nav-link" href="#moveis" onclick="scrollTo('moveis')">Móveis</a>
    <a class="nav-link" href="#eletronicos" onclick="scrollTo('eletronicos')">Eletrônicos</a>
    <a class="nav-link" href="#outros" onclick="scrollTo('outros')">Outros</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero" id="inicio">
  <h1>Achados Incríveis<br>a Preços Surreais 🛍</h1>
  <p>Eletrodomésticos, roupas, ferramentas e muito mais. Tudo com qualidade garantida e preço de brechó!</p>
  <div class="hero-badges">
    <span class="hero-badge">💵 Dinheiro ou PIX</span>
    <span class="hero-badge">🚚 Frete por conta do comprador</span>
    <span class="hero-badge">📱 Compre pelo WhatsApp</span>
  </div>
</section>

<!-- INFO STRIP -->
<div class="info-strip">
  <div class="info-strip-inner">
    <span class="info-item">💳 Pague no PIX ou dinheiro</span>
    <span class="info-item">📦 Frete por conta do comprador</span>
    <span class="info-item">📲 Atendimento pelo WhatsApp</span>
  </div>
</div>

<!-- MAIN CONTENT -->
<main>
  <div id="categorySections"></div>
</main>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">Brechó Surreal</div>
  <p>Achados incríveis a preços que parecem surreais!</p>
  <div class="pix-footer" id="footerPix">PIX: carregando...</div>
  <p style="margin-top:12px;font-size:0.75rem;opacity:0.6;">Frete por conta do comprador · Pagamento: Dinheiro ou PIX</p>
</footer>

